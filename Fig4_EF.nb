Cell[CellGroupData[{

Cell["Similar NF procedure to for second component", "Subsubsection",
 CellChangeTimes->{{3.943685905191671*^9, 3.943685916844166*^9}, {
  3.948184744863371*^9, 3.9481847481030703`*^9}, {3.9869518342818832`*^9, 
  3.986951843400146*^9}},ExpressionUUID->"82865822-77e5-42c9-ba11-\
6ecc41a28322"],

Cell[BoxData[
 RowBox[{
  RowBox[{"z", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"-", "1"}], "/", "Pi"}], " ", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"1", "x"}], "]"}], 
         RowBox[{
          RowBox[{"sol", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "[", 
          RowBox[{"t", ",", "x"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
        RowBox[{"Method", "->", 
         RowBox[{"{", 
          RowBox[{"Automatic", ",", 
           RowBox[{"\"\<SymbolicProcessing\>\"", "->", "0"}]}], "}"}]}], ",", 
        
        RowBox[{"AccuracyGoal", "->", "5"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "T"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.941798709061702*^9, 3.94179872356917*^9}, {
   3.943685977027319*^9, 3.943685995829771*^9}, {3.943686511399564*^9, 
   3.943686543769833*^9}, {3.943686902262355*^9, 3.943686902493979*^9}, {
   3.956128378200087*^9, 3.956128378972547*^9}, {3.9561286993739367`*^9, 
   3.956128702452207*^9}, {3.956129795386497*^9, 3.956129795493452*^9}, 
   3.95939975680369*^9},
 CellLabel->"In[59]:=",ExpressionUUID->"7ab60643-4ec6-4164-a7f7-863bec9e6fdf"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"times", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"i", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{
        RowBox[{"Dimensions", "[", "z", "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ztofit", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"times", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", 
       RowBox[{"z", "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{
        RowBox[{"Dimensions", "[", "z", "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "}"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9427562830298977`*^9, 3.942756295265585*^9}, {
  3.942756543272238*^9, 3.942756545999012*^9}, {3.9427565923279657`*^9, 
  3.942756594942704*^9}, {3.943606724059894*^9, 3.943606737541861*^9}, {
  3.943673231307261*^9, 3.943673241857257*^9}, {3.943686025571919*^9, 
  3.9436860354884663`*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"d494c1f2-7824-41ad-8db6-728f7c4d8fa3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rsol", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"DSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"r", "'"}], "[", "x", "]"}], "==", 
          RowBox[{
           RowBox[{"p1", " ", 
            RowBox[{"r", "[", "x", "]"}]}], "-", 
           RowBox[{"p2", " ", 
            RowBox[{
             RowBox[{"r", "[", "x", "]"}], "^", "3"}]}]}]}], ",", 
         RowBox[{
          RowBox[{"r", "[", "0", "]"}], "==", "r0"}]}], "}"}], ",", 
       RowBox[{"r", "[", "x", "]"}], ",", "x", ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"r0", ">", "0"}], ",", 
          RowBox[{"p1", ">", "0"}], ",", 
          RowBox[{"p2", ">", "0"}]}], "}"}]}]}], "]"}], "//", "Quiet"}], "//",
     "FullSimplify"}]}], ";"}]], "Input",
 CellLabel->"In[62]:=",ExpressionUUID->"24e5e19a-60a6-441f-8f56-2b0a853b9d14"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"functofit", "=", 
  RowBox[{
   RowBox[{"r", "[", "x", "]"}], "/.", 
   RowBox[{"rsol", "[", 
    RowBox[{"[", 
     RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}]], "Input",
 CellLabel->"In[63]:=",ExpressionUUID->"544b6df5-f9bc-45d7-88f6-c9ca5d797a22"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"p1", " ", "x"}]], " ", 
   SqrtBox["p1"], " ", "r0"}], 
  RowBox[{
   SqrtBox[
    RowBox[{"p1", "-", 
     RowBox[{"p2", " ", 
      SuperscriptBox["r0", "2"]}]}]], " ", 
   SqrtBox[
    RowBox[{"1", "+", 
     FractionBox[
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"2", " ", "p1", " ", "x"}]], " ", "p2", " ", 
       SuperscriptBox["r0", "2"]}], 
      RowBox[{"p1", "-", 
       RowBox[{"p2", " ", 
        SuperscriptBox["r0", "2"]}]}]]}]]}]]], "Output",
 CellChangeTimes->{
  3.943686067928985*^9, 3.9436861075334053`*^9, 3.943686335713559*^9, 
   3.943686911872767*^9, {3.9437102068103*^9, 3.943710221049065*^9}, {
