Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"dS2", "=", 
   RowBox[{"DiagonalMatrix", "[", 
    RowBox[{"{", 
     RowBox[{
     "0", ",", "0.05", ",", "0", ",", "1.", ",", "2.", ",", "0", ",", "0", ",",
       "0", ",", "0", ",", "0"}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Max", "[", 
    RowBox[{"Re", "[", 
     RowBox[{"Eigenvalues", "[", 
      RowBox[{"sparseJ", "-", 
       RowBox[{
        RowBox[{"k", "^", "2"}], "dS2"}]}], "]"}], "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", "0", ",", "5"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"GridLines", "->", "Automatic"}], ",", 
   RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}]}], "Input",
