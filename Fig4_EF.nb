Cell[BoxData[
 RowBox[{
  RowBox[{"sparseJ", "=", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\<data_TuringLargeNetwork/SparseJacobian.dat\>\"", 
     ",", "\"\<Table\>\""}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{
  3.943685813802561*^9, {3.9481845378686113`*^9, 3.948184560428516*^9}, 
