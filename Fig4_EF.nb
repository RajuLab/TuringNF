c152989fe07c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"z", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"1", "/", "Pi"}], " ", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{"1", "x"}], "]"}], 
         RowBox[{
          RowBox[{"sol", "[", 
           RowBox[{"[", "8", "]"}], "]"}], "[", 
          RowBox[{"t", ",", "x"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
        RowBox[{"Method", "->", 
         RowBox[{"{", 
          RowBox[{"Automatic", ",", 
           RowBox[{"\"\<SymbolicProcessing\>\"", "->", "0"}]}], "}"}]}], ",", 
        
        RowBox[{"AccuracyGoal", "->", "5"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "T"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"times", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"i", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{
        RowBox[{"Dimensions", "[", "z", "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ztofit", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"times", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", 
       RowBox[{"z", "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{
        RowBox[{"Dimensions", "[", "z", "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "}"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.941798709061702*^9, 3.94179872356917*^9}, {
  3.943685977027319*^9, 3.943685995829771*^9}, {3.943686511399564*^9, 
  3.943686543769833*^9}, {3.943686902262355*^9, 3.943686902493979*^9}, {
  3.956128378200087*^9, 3.956128378972547*^9}, {3.9561286993739367`*^9, 
  3.956128702452207*^9}, {3.986951774640562*^9, 3.9869517747449217`*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"3b992f76-fc1d-4d24-9280-9322844ce383"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rsol", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"DSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"r", "'"}], "[", "x", "]"}], "==", 
          RowBox[{
           RowBox[{"p1", " ", 
            RowBox[{"r", "[", "x", "]"}]}], "-", 
           RowBox[{"p2", " ", 
            RowBox[{
             RowBox[{"r", "[", "x", "]"}], "^", "3"}]}]}]}], ",", 
         RowBox[{
          RowBox[{"r", "[", "0", "]"}], "==", "r0"}]}], "}"}], ",", 
       RowBox[{"r", "[", "x", "]"}], ",", "x", ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"r0", ">", "0"}], ",", 
          RowBox[{"p1", ">", "0"}], ",", 
          RowBox[{"p2", ">", "0"}]}], "}"}]}]}], "]"}], "//", "Quiet"}], "//",
     "FullSimplify"}]}], ";"}]], "Input",
 CellLabel->"In[24]:=",ExpressionUUID->"cc624e7c-ead0-4ca3-a29a-41933c18d0aa"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"functofit", "=", 
  RowBox[{
   RowBox[{"r", "[", "x", "]"}], "/.", 
   RowBox[{"rsol", "[", 
    RowBox[{"[", 
     RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}]], "Input",
 CellLabel->"In[25]:=",ExpressionUUID->"7e2221c8-6901-4c47-b92c-3111bebc0920"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"p1", " ", "x"}]], " ", 
   SqrtBox["p1"], " ", "r0"}], 
  RowBox[{
   SqrtBox[
    RowBox[{"p1", "-", 
     RowBox[{"p2", " ", 
      SuperscriptBox["r0", "2"]}]}]], " ", 
   SqrtBox[
    RowBox[{"1", "+", 
     FractionBox[
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"2", " ", "p1", " ", "x"}]], " ", "p2", " ", 
       SuperscriptBox["r0", "2"]}], 
      RowBox[{"p1", "-", 
       RowBox[{"p2", " ", 
        SuperscriptBox["r0", "2"]}]}]]}]]}]]], "Output",
