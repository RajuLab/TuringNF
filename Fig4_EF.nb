 RowBox[{"u2plt2", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"sol", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "[", 
         RowBox[{"t", ",", "x"}], "]"}], "/.", 
        RowBox[{"t", "->", "t2"}]}], "/.", 
       RowBox[{"x", "->", 
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{"y", "-", "\[Omega]"}], ",", 
          RowBox[{"2", " ", "Pi"}], ",", 
          RowBox[{"-", "Pi"}]}], "]"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
