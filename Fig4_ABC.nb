Cell[BoxData[
 RowBox[{"plt2", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"csol", "[", 
        RowBox[{"t", ",", "x", ",", "0"}], "]"}], "/.", 
       RowBox[{"t", "->", 
        RowBox[{"5", "t2"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"k02", "+", 
         RowBox[{"z1t", " ", 
          RowBox[{"Cos", "[", "x", "]"}]}], "+", 
         RowBox[{"0.0242", 
          RowBox[{"z1t", "^", "2"}], 
          RowBox[{"Cos", "[", 
           RowBox[{"2", "x"}], "]"}]}], "+", 
         RowBox[{"0.00049", 
          RowBox[{"z1t", "^", "3"}], 
          RowBox[{"Cos", "[", 
           RowBox[{"3", "x"}], "]"}]}], "+", 
         RowBox[{"0.000009", 
          RowBox[{"z1t", "^", "4"}], 
          RowBox[{"Cos", "[", 
           RowBox[{"4", "x"}], "]"}]}]}], "/.", 
        RowBox[{"t", "->", "t2"}]}], "/.", "fp"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", 
     RowBox[{"{", 
      RowBox[{"10", ",", "80"}], "}"}]}], ",", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Blue"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Red"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
    RowBox[{"GridLines", "->", "Automatic"}], ",", 
    RowBox[{"BaseStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FontFamily", "->", "\"\<CMU Serif\>\""}], ",", "14"}], 
      "}"}]}]}], "]"}]}]], "Input",
