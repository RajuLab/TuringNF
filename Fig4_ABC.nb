Cell[CellGroupData[{

Cell["Fitting the data along x axis with NF equation", "Subsubsection",
 CellChangeTimes->{{3.986948850024407*^9, 
  3.986948870152184*^9}},ExpressionUUID->"05fc1e88-843b-4ffa-886b-\
582309b0acc5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", "Pi"}], " ", 
        RowBox[{"NIntegrate", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"k", " ", "x"}], "]"}], 
           RowBox[{"csol", "[", 
            RowBox[{"t", ",", "x", ",", "0"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", 
            RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
          RowBox[{"PrecisionGoal", "->", "4"}], ",", 
          RowBox[{"AccuracyGoal", "->", "5"}], ",", 
          RowBox[{"Method", "->", 
           RowBox[{"{", 
            RowBox[{"Automatic", ",", 
             RowBox[{"\"\<SymbolicProcessing\>\"", "->", "0"}]}], "}"}]}]}], 
         "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "T", ",", "5"}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "0", ",", "4"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9554350194250803`*^9, 3.955435047633415*^9}, {
  3.955435162723053*^9, 3.955435165100263*^9}, {3.955437495706339*^9, 
  3.955437495801702*^9}, {3.9561428038341017`*^9, 3.956142804696885*^9}},
