  3.98694874472046*^9}},ExpressionUUID->"f9bd3684-1fed-45c5-b141-\
e03e9d872fe8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[CapitalOmega]", "=", 
   RowBox[{"DiscretizeRegion", "[", 
    RowBox[{
     RowBox[{"Rectangle", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "L"}], ",", 
         RowBox[{"-", "L"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"L", ",", "L"}], "}"}]}], "]"}], ",", 
     RowBox[{"Method", "->", "\"\<Continuation\>\""}], ",", 
     RowBox[{"AccuracyGoal", "->", "7"}], ",", 
     RowBox[{"PrecisionGoal", "->", "7"}], ",", 
     RowBox[{"MaxCellMeasure", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Area\>\"", "->", "0.2"}], "}"}]}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{
  3.9554336384915857`*^9, 3.955439643010524*^9, {3.955440042866661*^9, 
   3.955440043074627*^9}, 3.955440938586494*^9, {3.9554473934780273`*^9, 
   3.955447394440467*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"20c2a0ca-c48d-4b40-8980-eb5037ba6471"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"L", "=", 
   RowBox[{"2", "Pi"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"T", "=", "100"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Eta]", "=", "5"}], ";"}]}], "Input",
 CellLabel->"In[16]:=",ExpressionUUID->"da7039cf-2de1-44b4-8755-a8ce3419e67f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"eqn", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", "\[Delta]"}], " ", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"a", "[", 
            RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", "1"}], "}"}]}], "]"}]}], "==", 
        RowBox[{
         RowBox[{"da", 
          RowBox[{"(", " ", 
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"a", "[", 
               RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "2"}], "}"}]}], "]"}], "+", 
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"a", "[", 
               RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"y", ",", "2"}], "}"}]}], "]"}]}], ")"}]}], "+", 
         RowBox[{"f", "[", 
          RowBox[{
           RowBox[{"a", "[", 
            RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
           RowBox[{"b", "[", 
            RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
           RowBox[{"c", "[", 
            RowBox[{"t", ",", "x", ",", "y"}], "]"}]}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", "\[Delta]"}], " ", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"b", "[", 
            RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", "1"}], "}"}]}], "]"}]}], "==", 
        RowBox[{
         RowBox[{"db", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"b", "[", 
               RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "2"}], "}"}]}], "]"}], "+", 
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"b", "[", 
               RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"y", ",", "2"}], "}"}]}], "]"}]}], ")"}]}], "+", 
         RowBox[{"g", "[", 
          RowBox[{
           RowBox[{"a", "[", 
            RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
           RowBox[{"b", "[", 
            RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
           RowBox[{"c", "[", 
            RowBox[{"t", ",", "x", ",", "y"}], "]"}]}], "]"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", "\[Delta]"}], " ", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"c", "[", 
            RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", "1"}], "}"}]}], "]"}]}], "==", 
        RowBox[{"h", "[", 
         RowBox[{
          RowBox[{"a", "[", 
           RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
          RowBox[{"b", "[", 
           RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
          RowBox[{"c", "[", 
           RowBox[{"t", ",", "x", ",", "y"}], "]"}]}], "]"}]}]}], "}"}], "/.",
      "eval"}], "/.", "fp"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9554322634178677`*^9, 3.95543236422631*^9}, {
  3.955432768560816*^9, 3.955432784694363*^9}, {3.9554334215068483`*^9, 
