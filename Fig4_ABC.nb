 CellLabel->"In[19]:=",ExpressionUUID->"9bda49ab-2137-4fed-a48e-efc1ce42972a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ic", "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"a", "[", 
         RowBox[{"0", ",", "x", ",", "y"}], "]"}], "==", 
        RowBox[{"a0", "+", 
         RowBox[{"0.01", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Cos", "[", "x", "]"}], "+", 
            RowBox[{"0.5", 
             RowBox[{"Cos", "[", 
              RowBox[{"2", "x"}], "]"}]}]}], ")"}]}]}]}], "/.", "fp"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"b", "[", 
         RowBox[{"0", ",", "x", ",", "y"}], "]"}], "==", 
        RowBox[{"b0", "+", 
         RowBox[{"0.01", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Cos", "[", "x", "]"}], "+", 
            RowBox[{"0", 
             RowBox[{"Cos", "[", 
              RowBox[{"2", "x"}], "]"}]}]}], ")"}]}]}]}], "/.", "fp"}], ",", 
      RowBox[{
       RowBox[{"c", "[", 
        RowBox[{"0", ",", "x", ",", "y"}], "]"}], "==", 
       RowBox[{"c0", "+", 
        RowBox[{"0.01", 
         RowBox[{"Cos", "[", "x", "]"}]}], "+", 
        RowBox[{"0.", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", "x"}], "]"}]}]}]}]}], "}"}], "/.", "fp"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{
  3.9554323876373463`*^9, {3.9554333881625967`*^9, 3.955433403497116*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"8d7e4666-e035-4217-80d8-5700fe10082a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pbc", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"PeriodicBoundaryCondition", "[", 
      RowBox[{
       RowBox[{"a", "[", 
        RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
       RowBox[{"x", "==", 
        RowBox[{"-", "L"}]}], ",", 
       RowBox[{"TranslationTransform", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", "L"}], ",", "0"}], "}"}], "]"}]}], "]"}], ",", 
     RowBox[{"PeriodicBoundaryCondition", "[", 
      RowBox[{
       RowBox[{"a", "[", 
        RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
       RowBox[{"y", "==", 
        RowBox[{"-", "L"}]}], ",", 
       RowBox[{"TranslationTransform", "[", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"2", "L"}]}], "}"}], "]"}]}], "]"}], ",", 
     RowBox[{"PeriodicBoundaryCondition", "[", 
      RowBox[{
       RowBox[{"b", "[", 
        RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
       RowBox[{"x", "==", 
        RowBox[{"-", "L"}]}], ",", 
       RowBox[{"TranslationTransform", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", "L"}], ",", "0"}], "}"}], "]"}]}], "]"}], ",", 
     RowBox[{"PeriodicBoundaryCondition", "[", 
      RowBox[{
       RowBox[{"b", "[", 
        RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
       RowBox[{"y", "==", 
        RowBox[{"-", "L"}]}], ",", 
       RowBox[{"TranslationTransform", "[", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"2", "L"}]}], "}"}], "]"}]}], "]"}], ",", 
     RowBox[{"PeriodicBoundaryCondition", "[", 
      RowBox[{
       RowBox[{"c", "[", 
        RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
       RowBox[{"x", "==", 
        RowBox[{"-", "L"}]}], ",", 
       RowBox[{"TranslationTransform", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", "L"}], ",", "0"}], "}"}], "]"}]}], "]"}], ",", 
     RowBox[{"PeriodicBoundaryCondition", "[", 
      RowBox[{
       RowBox[{"c", "[", 
        RowBox[{"t", ",", "x", ",", "y"}], "]"}], ",", 
       RowBox[{"y", "==", 
        RowBox[{"-", "L"}]}], ",", 
       RowBox[{"TranslationTransform", "[", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"2", "L"}]}], "}"}], "]"}]}], "]"}]}], "}"}]}], 
  ";"}]], "Input",
 CellLabel->"In[21]:=",ExpressionUUID->"3f9eb817-474b-4a38-9dbb-8fe09f1124a7"],

