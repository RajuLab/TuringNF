Cell[BoxData[
 RowBox[{"plt3", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"csol", "[", 
        RowBox[{"t", ",", "x", ",", "0"}], "]"}], "/.", 
       RowBox[{"t", "->", 
        RowBox[{"5", "t3"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"k03", "+", 
         RowBox[{"z1t", " ", 
          RowBox[{"Cos", "[", "x", "]"}]}], "+", 
         RowBox[{"0.0242", 
          RowBox[{"z1t", "^", "2"}], 
          RowBox[{"Cos", "[", 
           RowBox[{"2", "x"}], "]"}]}], "+", 
         RowBox[{"0.00049", 
          RowBox[{"z1t", "^", "3"}], 
          RowBox[{"Cos", "[", 
           RowBox[{"3", "x"}], "]"}]}], "+", 
         RowBox[{"0.000009", 
          RowBox[{"z1t", "^", "4"}], 
          RowBox[{"Cos", "[", 
           RowBox[{"4", "x"}], "]"}]}]}], "/.", 
        RowBox[{"t", "->", "t3"}]}], "/.", "fp"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
