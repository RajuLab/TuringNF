Cell[BoxData[
 RowBox[{
  RowBox[{"rsol", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"DSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"r", "'"}], "[", "x", "]"}], "==", 
          RowBox[{
           RowBox[{"p1", " ", 
            RowBox[{"r", "[", "x", "]"}]}], "-", 
           RowBox[{"p2", " ", 
            RowBox[{
             RowBox[{"r", "[", "x", "]"}], "^", "3"}]}]}]}], ",", 
         RowBox[{
          RowBox[{"r", "[", "0", "]"}], "==", "r0"}]}], "}"}], ",", 
       RowBox[{"r", "[", "x", "]"}], ",", "x", ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"r0", ">", "0"}], ",", 
          RowBox[{"p1", ">", "0"}], ",", 
          RowBox[{"p2", ">", "0"}]}], "}"}]}]}], "]"}], "//", "Quiet"}], "//",
     "FullSimplify"}]}], ";"}]], "Input",
