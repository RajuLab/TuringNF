Cell[CellGroupData[{

Cell["\<\
r and \[Theta] extracted from the data and fit to NF equation. Evolution \
along the radial (r) direction is fast compared with angular (\[Theta]) \
direction.\
\>", "Subsubsection",
 CellChangeTimes->{{3.9537106102655354`*^9, 3.953710619609672*^9}, {
  3.9537109146740437`*^9, 3.95371095655193*^9}, {3.986949258328415*^9, 
  3.986949317416153*^9}},ExpressionUUID->"1aebb31c-7bba-4af5-bae0-\
08023b3b52ef"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rdata", "=", 
   RowBox[{"Sqrt", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Re", "[", 
       RowBox[{"z", "[", 
        RowBox[{"[", 
         RowBox[{"1", ";;", "20"}], "]"}], "]"}], "]"}], "^", "2"}], "+", 
     RowBox[{
      RowBox[{"Im", "[", 
       RowBox[{"z", "[", 
        RowBox[{"[", 
         RowBox[{"1", ";;", "20"}], "]"}], "]"}], "]"}], "^", "2"}]}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.942756164608073*^9, 3.9427561688328238`*^9}, {
  3.9427562128077307`*^9, 3.942756265186803*^9}, {3.94360661889777*^9, 
  3.943606678300445*^9}, {3.943606933990128*^9, 3.943606937126534*^9}, {
