Cell[BoxData[{
 RowBox[{
  RowBox[{"eqn", "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"a", "[", 
          RowBox[{"t", ",", "x"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "1"}], "}"}]}], "]"}], "==", 
       RowBox[{
        RowBox[{"c", "[", 
         RowBox[{"t", ",", "x"}], "]"}], "-", 
        RowBox[{"ka", " ", 
         RowBox[{"a", "[", 
          RowBox[{"t", ",", "x"}], "]"}]}], "+", 
        RowBox[{"Da", " ", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"a", "[", 
            RowBox[{"t", ",", "x"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "2"}], "}"}]}], "]"}]}], "-", 
        RowBox[{
         RowBox[{"a", "[", 
          RowBox[{"t", ",", "x"}], "]"}], "^", "3"}], "+", 
        RowBox[{"0.001", 
         RowBox[{"Cos", "[", "x", "]"}]}]}]}], ",", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"b", "[", 
          RowBox[{"t", ",", "x"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "1"}], "}"}]}], "]"}], "==", 
       RowBox[{
        RowBox[{"c", "[", 
         RowBox[{"t", ",", "x"}], "]"}], "-", 
        RowBox[{"kb", " ", 
         RowBox[{"b", "[", 
          RowBox[{"t", ",", "x"}], "]"}]}], "+", 
        RowBox[{"Db", " ", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"b", "[", 
            RowBox[{"t", ",", "x"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "2"}], "}"}]}], "]"}]}], "-", 
        RowBox[{
         RowBox[{"b", "[", 
          RowBox[{"t", ",", "x"}], "]"}], "^", "3"}]}]}], ",", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"t", ",", "x"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "1"}], "}"}]}], "]"}], "==", 
       RowBox[{
        RowBox[{"\[Alpha]", " ", 
         RowBox[{"a", "[", 
          RowBox[{"t", ",", "x"}], "]"}]}], "-", 
        RowBox[{"\[Beta]", " ", 
         RowBox[{"b", "[", 
          RowBox[{"t", ",", "x"}], "]"}]}], "+", 
        RowBox[{"\[Gamma]", " ", 
         RowBox[{"c", "[", 
          RowBox[{"t", ",", "x"}], "]"}]}], "-", 
        RowBox[{
         RowBox[{"c", "[", 
          RowBox[{"t", ",", "x"}], "]"}], "^", "3"}]}]}]}], "}"}], "/.", 
    "eval"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ic", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"a", "[", 
       RowBox[{"0", ",", "x"}], "]"}], "==", "0"}], ",", 
     RowBox[{
      RowBox[{"b", "[", 
       RowBox[{"0", ",", "x"}], "]"}], "==", 
      RowBox[{"0.3", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"Cos", "[", "x", "]"}]}], "+", 
         RowBox[{"Sin", "[", "x", "]"}]}], ")"}]}]}], ",", 
     RowBox[{
      RowBox[{"c", "[", 
       RowBox[{"0", ",", "x"}], "]"}], "==", "0"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bc", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"a", "[", 
       RowBox[{"t", ",", 
        RowBox[{"-", "Pi"}]}], "]"}], "==", 
      RowBox[{"a", "[", 
       RowBox[{"t", ",", "Pi"}], "]"}]}], ",", 
     RowBox[{
      RowBox[{"b", "[", 
       RowBox[{"t", ",", 
        RowBox[{"-", "Pi"}]}], "]"}], "==", 
      RowBox[{"b", "[", 
       RowBox[{"t", ",", "Pi"}], "]"}]}], ",", 
     RowBox[{
      RowBox[{"c", "[", 
       RowBox[{"t", ",", 
        RowBox[{"-", "Pi"}]}], "]"}], "==", 
      RowBox[{"c", "[", 
       RowBox[{"t", ",", "Pi"}], "]"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"asol", ",", "bsol", ",", "csol"}], "}"}], "=", 
    RowBox[{"NDSolveValue", "[", 
