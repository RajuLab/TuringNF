Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"plt2", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"asol", "[", 
       RowBox[{
        RowBox[{"20", 
         RowBox[{"(", 
          RowBox[{"t2", "-", "1"}], ")"}]}], ",", "x"}], "]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"rt", " ", 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "2", 
            RowBox[{"ArcTan", "[", 
             RowBox[{
              RowBox[{"Tan", "[", "a", "]"}], 
              RowBox[{"Exp", "[", 
               RowBox[{"b", " ", "t"}], "]"}]}], "]"}]}], "]"}], 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "x"}], "]"}]}], "+", 
         RowBox[{"Conjugate", "[", 
          RowBox[{"rt", " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "2", 
             RowBox[{"ArcTan", "[", 
