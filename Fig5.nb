  3.956058382608477*^9, 3.9560583834023*^9}, {3.956114798091826*^9, 
  3.95611479819093*^9}, {3.956114875993649*^9, 3.9561148933251963`*^9}, {
  3.956114936010483*^9, 3.956114955239826*^9}, {3.956115026218359*^9, 
  3.9561150264725018`*^9}},
