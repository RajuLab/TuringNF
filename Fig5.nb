Cell[CellGroupData[{
Cell["NF theory with non-homogeneous production (field)", "Section",
 CellChangeTimes->{{3.95597313440131*^9, 3.955973141749763*^9}, {
  3.9561132641365747`*^9, 3.956113266982133*^9}, {3.986949187920497*^9, 
  3.9869492082881804`*^9}},ExpressionUUID->"7a946c84-8f93-45fc-a723-\
37ef99486836"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"eval", "=", 
  RowBox[{"Thread", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "ka", ",", "kb", ",", "\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]", ",", 
      "Da", ",", "Db"}], "}"}], "->", 
    RowBox[{"{", 
     RowBox[{"1", ",", "1", ",", "0.25", ",", "0.25", ",", 
      RowBox[{"-", "0.05"}], ",", "1", ",", "4"}], "}"}]}], "]"}]}]], "Input",\

 CellChangeTimes->{{3.956113120637574*^9, 3.9561131670912237`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"db596200-97f2-4a79-ae5c-ad358634fe9f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"ka", "\[Rule]", "1"}], ",", 
   RowBox[{"kb", "\[Rule]", "1"}], ",", 
   RowBox[{"\[Alpha]", "\[Rule]", "0.25`"}], ",", 
   RowBox[{"\[Beta]", "\[Rule]", "0.25`"}], ",", 
   RowBox[{"\[Gamma]", "\[Rule]", 
    RowBox[{"-", "0.05`"}]}], ",", 
   RowBox[{"Da", "\[Rule]", "1"}], ",", 
   RowBox[{"Db", "\[Rule]", "4"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.956113150794491*^9, 3.956113167743832*^9}, 
   3.957397738791108*^9, 3.958550778138418*^9, 3.986949211378976*^9},
 CellLabel->"Out[1]=",ExpressionUUID->"9e981fef-e9b2-44cc-840d-0902dffe01ce"]
}, Open  ]],

Cell[BoxData[{
 RowBox[{
  RowBox[{"j", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "ka"}], ",", "0", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"-", "kb"}], ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]", ",", 
       RowBox[{"-", "\[Beta]"}], ",", "\[Gamma]"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"jd", "=", 
   RowBox[{"j", "-", 
    RowBox[{
     RowBox[{"k", "^", "2"}], 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"Da", ",", "Db", ",", "0"}], "}"}], "]"}]}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{
  3.956113119190501*^9, {3.956113171456654*^9, 3.956113195934774*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"7a015051-28bb-4997-bf29-5b4b4b99b791"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Max", "[", 
    RowBox[{"Re", "[", 
     RowBox[{"Eigenvalues", "[", 
      RowBox[{"jd", "/.", "eval"}], "]"}], "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", "0", ",", "4"}], "}"}], ",", 
   RowBox[{"PlotStyle", "->", 
