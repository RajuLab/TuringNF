Cell[CellGroupData[{

Cell["Fitting the physical solution at three timepoints ", "Subsubsection",
 CellChangeTimes->{{3.986949388632135*^9, 
  3.986949403977013*^9}},ExpressionUUID->"dd0def92-32d7-4e8e-852b-\
9ffc1345650a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"t1", ",", "t2", ",", "t3"}], "}"}], "=", 
   RowBox[{"{", 
    RowBox[{"5", ",", "20", ",", "200"}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.956116211150337*^9, 3.956116230307014*^9}},
 CellLabel->"In[34]:=",ExpressionUUID->"5ec0358b-2c14-4220-8e67-0041269e6721"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"plt1", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"asol", "[", 
       RowBox[{
        RowBox[{"20", 
         RowBox[{"(", 
          RowBox[{"t1", "-", "1"}], ")"}]}], ",", "x"}], "]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"rt", " ", 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "2", 
            RowBox[{"ArcTan", "[", 
             RowBox[{
              RowBox[{"Tan", "[", "a", "]"}], 
              RowBox[{"Exp", "[", 
               RowBox[{"b", " ", "t"}], "]"}]}], "]"}]}], "]"}], 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "x"}], "]"}]}], "+", 
         RowBox[{"Conjugate", "[", 
          RowBox[{"rt", " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "2", 
             RowBox[{"ArcTan", "[", 
              RowBox[{
               RowBox[{"Tan", "[", "a", "]"}], 
               RowBox[{"Exp", "[", 
                RowBox[{"b", " ", "t"}], "]"}]}], "]"}]}], "]"}], 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "x"}], "]"}]}], "]"}]}], "/.", 
        RowBox[{"t", "->", "t1"}]}], "/.", 
       RowBox[{"nlm", "[", "\"\<BestFitParameters\>\"", "]"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "0.12"}], ",", "0.12"}], "}"}]}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
    RowBox[{"GridLines", "->", "Automatic"}], ",", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Red"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Blue"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"BaseStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FontFamily", "->", "\"\<CMU Serif\>\""}], ",", 
       RowBox[{"FontSize", "->", "14"}]}], "}"}]}]}], "]"}]}]], "Input",
