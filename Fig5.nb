Cell[BoxData[
 RowBox[{"plt3", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"asol", "[", 
       RowBox[{
        RowBox[{"20", 
         RowBox[{"(", 
          RowBox[{"t3", "-", "1"}], ")"}]}], ",", "x"}], "]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"rt", " ", 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "2", 
            RowBox[{"ArcTan", "[", 
             RowBox[{
              RowBox[{"Tan", "[", "a", "]"}], 
              RowBox[{"Exp", "[", 
               RowBox[{"b", " ", "t"}], "]"}]}], "]"}]}], "]"}], 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "x"}], "]"}]}], "+", 
         RowBox[{"Conjugate", "[", 
          RowBox[{"rt", " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "2", 
             RowBox[{"ArcTan", "[", 
              RowBox[{
               RowBox[{"Tan", "[", "a", "]"}], 
               RowBox[{"Exp", "[", 
                RowBox[{"b", " ", "t"}], "]"}]}], "]"}]}], "]"}], 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "x"}], "]"}]}], "]"}]}], "/.", 
        RowBox[{"t", "->", "t3"}]}], "/.", 
       RowBox[{"nlm", "[", "\"\<BestFitParameters\>\"", "]"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "0.12"}], ",", "0.12"}], "}"}]}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
    RowBox[{"GridLines", "->", "Automatic"}], ",", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Red"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Blue"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"BaseStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FontFamily", "->", "\"\<CMU Serif\>\""}], ",", 
       RowBox[{"FontSize", "->", "14"}]}], "}"}]}]}], "]"}]}]], "Input",
