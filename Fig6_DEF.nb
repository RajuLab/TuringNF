Cell[CellGroupData[{

Cell["Adding coefficients manually", "Subsubsection",
 CellChangeTimes->{{3.9564782297289047`*^9, 
  3.956478237159288*^9}},ExpressionUUID->"25befb62-16d0-401a-92e8-\
39b61782c4ea"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"plt1", "=", 
  RowBox[{"Show", "[", 
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"a", " ", 
         RowBox[{"shiftevright", "[", 
          RowBox[{"x", ",", "s1"}], "]"}]}], "+", " ", 
        RowBox[{"b", " ", 
         RowBox[{"shiftev", "[", 
          RowBox[{"x", ",", "s2"}], "]"}]}], "+", 
        RowBox[{"c", " ", 
         RowBox[{"shiftevleft", "[", 
          RowBox[{"x", ",", "s3"}], "]"}]}]}], "/.", 
       RowBox[{"Thread", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"a", ",", "b", ",", "c"}], "}"}], "->", 
         RowBox[{"{", 
          RowBox[{"9", ",", "0.0", ",", "0.0"}], "}"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "x0", ",", 
        RowBox[{"xL", "-", "1.5"}]}], "}"}], ",", 
      RowBox[{"PlotRange", "->", "All"}]}], "]"}], ",", 
    RowBox[{"ListLinePlot", "[", "d1x", "]"}], ",", 
    RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.956478640632283*^9, 3.956478647263236*^9}, {
