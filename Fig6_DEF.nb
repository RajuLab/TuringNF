       RowBox[{"b", " ", 
        RowBox[{"shiftev", "[", 
         RowBox[{"x", ",", "s2"}], "]"}]}], "+", 
       RowBox[{"c", " ", 
        RowBox[{"shiftevleft", "[", 
         RowBox[{"x", ",", "s3"}], "]"}]}]}], "/.", 
      RowBox[{"Thread", "[", 
