          RowBox[{"a", "[", "x", "]"}]}], "+", 
         RowBox[{"\[Beta]", " ", 
          RowBox[{"b", "[", "x", "]"}]}], "+", 
         RowBox[{"da", " ", 
          RowBox[{
           RowBox[{"a", "''"}], "[", "x", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"\[Gamma]", " ", 
          RowBox[{"a", "[", "x", "]"}]}], "+", 
         RowBox[{"\[Delta]", " ", 
          RowBox[{"b", "[", "x", "]"}]}], "+", 
         RowBox[{"db", " ", 
