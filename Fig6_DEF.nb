    RowBox[{
     RowBox[{"DSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"r", "'"}], "[", "t", "]"}], "==", 
          RowBox[{
           RowBox[{"a1", " ", 
            RowBox[{"r", "[", "t", "]"}]}], "-", 
           RowBox[{"a2", " ", 
            RowBox[{
             RowBox[{"r", "[", "t", "]"}], "^", "3"}]}]}]}], ",", 
         RowBox[{
          RowBox[{"r", "[", "0", "]"}], "==", "r0"}]}], "}"}], ",", 
       RowBox[{"r", "[", "t", "]"}], ",", "t", ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"r0", ">", "0"}], ",", 
          RowBox[{"p1", ">", "0"}], ",", 
          RowBox[{"p2", ">", "0"}]}], "}"}]}]}], "]"}], "//", "Quiet"}], "//",
