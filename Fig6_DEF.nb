      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"evbox", "[", "xShifted", "]"}]}], ",", 
          RowBox[{"0", "<=", "xShifted", "<=", "xL"}]}], "}"}], "}"}], ",", 
       "0"}], "]"}]}]}], "]"}]}]], "Input",
