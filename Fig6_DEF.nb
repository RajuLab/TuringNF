  RowBox[{"shiftev", "[", 
   RowBox[{
    RowBox[{"x_", "?", "NumericQ"}], ",", "delta_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "xShifted", "}"}], ",", 
    RowBox[{
